# Caliber158 — copy to .env and adjust
# Loaded by: scripts/load-env.sh (pixi) and python/env_config.py

# --- Target model (teacher) ---
# HuggingFace hub id or local path under CALIBER158_MODELS_DIR
CALIBER158_MODEL=Qwen/Qwen2.5-0.5B
# Downloaded weights + HF cache live here (not ~/.cache/huggingface)
CALIBER158_MODELS_DIR=models
CALIBER158_HIDDEN_SIZE=896
CALIBER158_INTERMEDIATE_SIZE=4864
CALIBER158_NUM_LAYERS=24

# Chain to extract / train (layer 0, neuron 0)
CALIBER158_LAYER=0
CALIBER158_NEURON=0

# Dataset generation
CALIBER158_SAMPLES=100000
CALIBER158_SEED=42
CALIBER158_DATA_DIR=data/chains
# 1 = random teacher (no HuggingFace download)
CALIBER158_SYNTHETIC=0
# Teacher extract device: cuda (default) or cpu
CALIBER158_TORCH=cuda

# Student train device: cuda (default if available) or cpu
CALIBER158_DEVICE=cuda
# Student train backend (mojo only)
CALIBER158_TRAIN_BACKEND=mojo

# --- Student micro-network (Mojo) ---
CALIBER158_HIDDEN_DIM=128
CALIBER158_DATASET=data/chains/L00_N0000.bin

# Training
CALIBER158_EPOCHS=10
CALIBER158_BATCH_SIZE=64
CALIBER158_LR=0.001
CALIBER158_WEIGHT_DECAY=0.01
CALIBER158_ADAM_BETA1=0.9
CALIBER158_ADAM_BETA2=0.999
CALIBER158_ADAM_EPS=1e-8
CALIBER158_LOG_EVERY=1
CALIBER158_INIT_SCALE=0.1
# v1 block2 (H→H): unset = INIT_SCALE/HIDDEN_DIM; set to override
# CALIBER158_INIT_SCALE_BLOCK2=0.001
# v1 residual: h = h1 + scale*h2; unset = 1/HIDDEN_DIM
# CALIBER158_BLOCK2_RESIDUAL_SCALE=0.002
CALIBER158_TERNARY_THRESHOLD=0.0

# Smoke test (quick sanity run)
CALIBER158_SMOKE_EPOCHS=3
CALIBER158_SMOKE_BATCH_SIZE=32
CALIBER158_SMOKE_SAMPLES=128
